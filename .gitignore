.DS_Store
.AppleDouble
.LSOverride

# Gradle build output
build/

# Gradle daemon and local cache
.gradle/

# Gradle wrapper JAR is intentionally committed so anyone can run ./gradlew
# without installing Gradle. Un-comment the line below only if you prefer
# to require a local Gradle installation instead:
# gradle/wrapper/gradle-wrapper.jar

# Compiled Java classes (safety net; build/ already covers these)
*.class

