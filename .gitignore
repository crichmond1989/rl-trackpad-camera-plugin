.idea/
*.iml
*.iws
out/

# VS Code — user-specific files only; launch.json and tasks.json are committed
.vscode/settings.json
.vscode/*.log

# Claude Code — local project state written by Claude Code CLI
# CLAUDE.md is intentionally tracked; .claude/ is local machine state
.claude/

